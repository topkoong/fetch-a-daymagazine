{
  "name": "fetch-a-daymagazine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://topkoong.github.io/fetch-a-daymagazine",
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=25.8.2"
  },
  "keywords": [
    "pnpm",
    "preact",
    "vite",
    "typescript",
    "ghactions",
    "vitest",
    "eslint",
    "prettier",
    "husky",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "vite",
    "cache:build": "bash ./cachescripts/fetch-a-day-posts.sh && bash ./cachescripts/fetch-a-day-categories.sh && bash ./cachescripts/fetch-a-day-post-details.sh",
    "cache:details": "bash ./cachescripts/fetch-a-day-post-details.sh",
    "build": "tsc && vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:format": "prettier --log-level warn --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "lint": "pnpm lint:format && pnpm lint:fix",
    "type-check": "tsc",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.12",
    "preact": "^10.28.2",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/postcss": "^4.1.18",
    "axios": "^1.13.4",
    "eslint": "^10.1.0",
    "eslint-config-preact": "^2.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json}": [
      "prettier --log-level warn --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-config-preact>eslint": "10",
        "eslint-plugin-import>eslint": "10",
        "eslint-plugin-react-hooks>eslint": "10",
        "typescript-eslint>typescript": "6"
      }
    }
  }
}
